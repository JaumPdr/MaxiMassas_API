{
  // String de conexão com o banco SQL Server
  "ConnectionStrings": {
    "DefaultConnection": "Server=JPDESKTOP;Database=MaxiMassasDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  // Configurações utilizadas para geração e validação do JWT
  "JwtSettings": {

    // Chave secreta usada para assinar os tokens
    "SecretKey": "MaxiMassas@2024#SecretKey!SuperSegura$1234567890",

    // Emissor do token JWT
    "Issuer": "MaxiMassasAPI",

    // Público permitido para utilizar o token
    "Audience": "MaxiMassasClientes",

    // Tempo de expiração do token em horas
    "ExpirationHours": 8
  },

  // Configurações relacionadas ao cálculo de frete
  "FreteConfig": {

    // Valor padrão do frete do delivery
    "ValorFreteUaiRango": 5.00,

    // Valor mínimo para frete grátis
    "ValorMinimoFreteGratis": 80.00
  },

  // Configurações de logs da aplicação
  "Logging": {
    "LogLevel": {

      // Nível padrão de logs da aplicação
      "Default": "Information",

      // Exibe apenas avisos do ASP.NET Core
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Permite acesso da aplicação de qualquer host
  "AllowedHosts": "*"
}